# Supabase 邮箱登录所需配置
# 在 Supabase 控制台 → Project Settings → API 复制
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Supabase 控制台 → Authentication → URL Configuration：
# Site URL: http://localhost:3000
# Redirect URLs: http://localhost:3000/auth/callback
# 生产环境还需要加入 https://your-domain.com/auth/callback

# 站内 AI 工具用的 DeepSeek（可选，未配置时 /tools/red-generator 不可用）
DEEPSEEK_API_KEY=

# 抖音解析免费上游（默认 https://api.douyin.wtf，可改自建反代）
DOUYIN_API_BASE=
